{
  "name": "@peryskop/ui",
  "version": "0.0.1",
  "description": "Shared UI library for Peryskop (React Native + React web) built on Tamagui",
  "private": true,
  "sideEffects": [
    "*.css"
  ],
  "engines": {
    "node": ">=20"
  },
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/types/index.d.ts",
  "react-native": "src/index.ts",
  "source": "src/index.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "react-native": "./src/index.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./tamagui.config": {
      "types": "./dist/types/config/tamagui.config.d.ts",
      "react-native": "./src/config/tamagui.config.ts",
      "import": "./dist/esm/config/tamagui.config.js",
      "require": "./dist/cjs/config/tamagui.config.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tamagui-build",
    "watch": "tamagui-build --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist storybook-static",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@tamagui/config": "^1.144.4"
  },
  "peerDependencies": {
    "react": ">=18.2.0",
    "react-native": "*",
    "tamagui": ">=1.140.0"
  },
  "peerDependenciesMeta": {
    "react-native": {
      "optional": true
    }
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^9.1.0",
    "@storybook/addon-docs": "^9.1.0",
    "@storybook/addon-themes": "^9.1.0",
    "@storybook/react-vite": "^9.1.0",
    "@tamagui/build": "^1.144.4",
    "@tamagui/vite-plugin": "^1.144.4",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-native": "0.79.0",
    "react-native-web": "^0.20.0",
    "rimraf": "^6.0.1",
    "storybook": "^9.1.0",
    "tamagui": "^1.144.4",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  },
  "overrides": {
    "react": "$react",
    "react-dom": "$react-dom",
    "@types/react": "$@types/react",
    "@types/react-dom": "$@types/react-dom"
  }
}
