{
  "name": "@peryskop/ui",
  "version": "0.0.1",
  "description": "Shared UI library for Peryskop (React Native + React web) built on Tamagui",
  "private": true,
  "sideEffects": [
    "*.css"
  ],
  "engines": {
    "node": ">=20"
  },
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/types/index.d.ts",
  "react-native": "src/index.ts",
  "source": "src/index.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "react-native": "./src/index.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./tamagui.config": {
      "types": "./dist/types/config/tamagui.config.d.ts",
      "react-native": "./src/config/tamagui.config.ts",
      "import": "./dist/esm/config/tamagui.config.js",
      "require": "./dist/cjs/config/tamagui.config.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tamagui-build",
    "watch": "tamagui-build --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "rimraf dist storybook-static",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md,css,mdx,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@tamagui/config": "^1.144.4"
  },
  "peerDependencies": {
    "react": ">=18.2.0",
    "react-native": "*",
    "tamagui": ">=1.140.0"
  },
  "peerDependenciesMeta": {
    "react-native": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@storybook/addon-a11y": "^9.1.0",
    "@storybook/addon-docs": "^9.1.0",
    "@storybook/addon-themes": "^9.1.0",
    "@storybook/react-vite": "^9.1.0",
    "@tamagui/build": "^1.144.4",
    "@tamagui/vite-plugin": "^1.144.4",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.15.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-storybook": "^0.11.0",
    "eslint-plugin-unused-imports": "^4.1.4",
    "globals": "^15.12.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10",
    "prettier": "^3.4.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-native": "0.79.0",
    "react-native-web": "^0.20.0",
    "rimraf": "^6.0.1",
    "storybook": "^9.1.0",
    "tamagui": "^1.144.4",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.15.0",
    "vite": "^6.0.0"
  },
  "overrides": {
    "react": "$react",
    "react-dom": "$react-dom",
    "@types/react": "$@types/react",
    "@types/react-dom": "$@types/react-dom"
  }
}
